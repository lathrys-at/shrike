# Shrike Bazel configuration.
#
# Machine/personal overrides go in .bazelrc.user (gitignored), e.g. a local
# build cache:
#   build --disk_cache=/Users/you/.cache/shrike/bazel-disk
# NOTE: Bazel does NOT expand ~ in flags — use an absolute path. CI passes
# --disk_cache explicitly (persisted via actions/cache), so it isn't hardcoded here.

# Readable, non-truncated test failures.
test --test_output=errors

# Stamp the build with the tag-derived version (STABLE_VERSION) so py_wheel (#245)
# can embed it. Cheap (a `git describe`); only stamped outputs (the wheel) rebuild
# on a version change, since it lands in stable-status.txt.
build --workspace_status_command=tools/workspace_status.sh

# Auto-apply the host-OS config below (build:linux on linux, etc.).
common --enable_platform_specific_config

# #417: on aarch64-linux, cxx's C++ object (cxx_cc, via usearch) references
# GCC's outline-atomics helpers (__aarch64_ldadd4_acq_rel, …), which live in
# the STATIC libgcc.a — and the rustc-driven link (-nodefaultlibs + -lgcc_s,
# the shared lib only) never supplies them, so every target linking cxx fails
# on the arm lane. Appending -lgcc resolves them; trailing position is right
# for a static archive, and on linux x64 it's inert (no outline atomics).
# rules_rust forwards --linkopt into rustc links as --codegen=link-arg.
build:linux --linkopt=-lgcc

try-import %workspace%/.bazelrc.user
