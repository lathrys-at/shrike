# Shrike Bazel configuration.
#
# Machine/personal overrides go in .bazelrc.user (gitignored), e.g. a local
# build cache:
#   build --disk_cache=/Users/you/.cache/shrike/bazel-disk
# NOTE: Bazel does NOT expand ~ in flags — use an absolute path. CI passes
# --disk_cache explicitly (persisted via actions/cache), so it isn't hardcoded here.

# Readable, non-truncated test failures.
test --test_output=errors

try-import %workspace%/.bazelrc.user
