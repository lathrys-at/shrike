# The embedding runtime + the in-process backends (onnx/clip) as one cluster:
# runtime.py constructs the backends lazily, and they share the probe/text
# helpers, so they version together. onnxruntime stays out (lazy heavy import).
py_library(
    name = "embedding",
    srcs = [
        "harness/engines/embedding/clip.py",
        "harness/engines/embedding/onnx.py",
        "harness/engines/embedding/onnx_common.py",
        "harness/engines/embedding/runtime.py",
    ],
    imports = [".."],
    deps = [
        ":embed_batching",
        ":embed_text",
        ":embedding_base",
        ":pkg",
        "//shrike-core/shrike-pyo3:shrike_native",
    ],
)

# --- assembly tier ----------------------------------------------------------

py_library(
    name = "harness",
    srcs = ["harness/harness.py"],
    imports = [".."],
    deps = [
        ":actions",  # #68 routing: CollectionBundle (lazy, in resolve_bundle)
        ":cache_layout",  # #68 routing: per-collection index/derived paths
        ":cli_core",  # #68 routing: re-reads the registry via cli.config.load_config (lazy)
        ":collection",
        ":derived",
        ":embedding",
        ":embedding_base",
        ":index",  # #580/#730: ACTIVATION_MARGIN (the cross-space floor margin default)
        ":pkg",
        ":profiles",
        ":recognition",
        ":registry",  # #68 routing: the live registry view
        "//shrike-core/shrike-pyo3:shrike_native",
    ],
)

py_library(
    name = "actions",
    srcs = ["api/actions.py"],
    imports = [".."],
    deps = [
        ":collection",
        ":derived",
        ":index",
        ":pathsafety",  # export_package's server-local output gate (#71)
        ":pkg",
        ":schemas",
        "//shrike-core/shrike-pyo3:shrike_native",
        requirement("pydantic"),
    ],
)

py_library(
    name = "tools",
    srcs = [
        "api/mcp_adapter.py",
        "api/tools.py",
    ],
    imports = [".."],
    deps = [
        ":actions",
        ":collection",
        ":derived",
        ":pkg",
        "//shrike-core/shrike-pyo3:shrike_native",
        requirement("mcp"),
    ],
)

# The dependency-light half of the cli package: the root Click group (lazy
# subcommands), config loading, and output formatting. Split from :cli so
# server.py's lazy `cli.config.load_config` import doesn't cycle (server →
# :cli_core; :cli → :server).
py_library(
    name = "cli_core",
    srcs = [
        "cli/__init__.py",
        "cli/config.py",
        "cli/groups.py",  # OrderedGroup, imported by the root group in __init__.py
        "cli/output.py",
    ],
    imports = [".."],
    deps = [
        ":client",
        ":errors",
        ":index",  # cli/config resolves the cross-space margin from ACTIVATION_MARGIN (lazy)
        ":paths",
        ":pkg",
        ":profiles",
        ":registry",  # config.py lazily writes the profiles: section via the registry model
        ":schemas",
        "//shrike-core/shrike-pyo3:shrike_native",
        requirement("click"),
        requirement("pydantic"),
        requirement("pyyaml"),
        requirement("rich"),
    ],
)

py_library(
    name = "server",
    srcs = [
        "server/__init__.py",
        "server/__main__.py",
        "server/_mcp_perf.py",
        "server/server.py",
    ],
    imports = [".."],
    deps = [
        ":cache_layout",  # server.py resolves the namespaced derived-store path (#547)
        ":cli_core",
        ":collection",
        ":daemon",
        ":derived",
        ":embedding",
        ":export_store",  # the export download store (#71)
        ":harness",
        ":log",
        ":paths",
        ":pathsafety",  # server-local path-safety helpers (#71)
        ":pkg",
        ":profiles",
        ":schemas",
        ":tools",
        "//shrike-core/shrike-pyo3:shrike_native",
        requirement("mcp"),
    ],
)

# The cli command modules (lazy-loaded by the root group in :cli_core).
# server_cmd lazily imports shrike.server for foreground mode, hence :server.
py_library(
    name = "cli",
    srcs = glob(
        ["cli/*.py"],
        exclude = [
            "cli/__init__.py",
            "cli/config.py",
            "cli/groups.py",  # lives in :cli_core (the root group imports it)
            "cli/output.py",
        ],
    ),
    imports = [".."],
    deps = [
        ":cli_core",
        ":client",
        ":daemon",
        ":embedding",
        ":log",
        ":pkg",
        ":profiles",
        ":registry",  # cli/profile_cmd.py
        ":schemas",
        ":server",
        requirement("click"),
    ],
)

# --- the umbrella -----------------------------------------------------------

# The whole package, for consumers that genuinely want all of it: //shrike-py/bin's
# launchers, //shrike-py:wheel, the integration/native suites. No srcs of its own —
# every module lives in exactly one sub-library above.
py_library(
    name = "shrike",
    deps = [
        ":actions",
        ":cache_layout",
        ":cli",
        ":cli_core",
        ":client",
        ":collection",
        ":daemon",
        ":derived",
        ":embed_batching",
        ":embed_text",
        ":embedding",
        ":embedding_base",
        ":errors",
        ":export_store",
        ":harness",
        ":index",
        ":log",
        ":paths",
        ":pathsafety",
        ":pkg",
        ":profiles",
        ":recognition",
        ":registry",
        ":schemas",
        ":search_fusion",
        ":server",
        ":tools",
    ],
)

# PEP 561 marker. A py_library's `data` isn't pulled into a py_wheel, but a filegroup
# named in the wheel's `deps` is — so the wheel ships shrike/py.typed (matching the
# hatchling wheel; see tools/check-wheel-parity.sh).
filegroup(
    name = "py_typed",
    srcs = ["py.typed"],
)

# The package sources for //shrike-py:wheel. py_wheel packages only the DIRECT files of its
# deps (it does not walk a py_library's transitive closure), so the srcs-less
# :shrike umbrella contributes nothing — the wheel names this glob instead. A glob
# is right here: the artifact wants "the whole package tree" regardless of how the
# build graph slices it. _version.py is excluded deliberately — the Bazel wheel
# resolves its version via importlib.metadata (see __init__.py and the IGNORE_FILES
# note in tools/check-wheel-parity.sh), and a stale locally-generated copy must not
# leak into the release artifact.
filegroup(
    name = "wheel_srcs",
    srcs = glob(
        ["**/*.py"],
        exclude = ["_version.py"],
    ),
)

# Source files for the //shrike-py:sdist source distribution (#245) — the package tree minus
# the BUILD file, generated _version.py, and bytecode.
filegroup(
    name = "dist_files",
    srcs = glob(
        ["**"],
        exclude = ["BUILD.bazel", "_version.py", "**/__pycache__/**", "**/*.pyc", "**/*.pyo"],
    ),
    visibility = ["//visibility:public"],
)
