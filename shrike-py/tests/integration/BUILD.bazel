load("@rules_python//python:defs.bzl", "py_library")
load("@shrike_pip//:requirements.bzl", "requirement")
load("//tools/bazel:defs.bzl", "pytest_test")

package(default_testonly = True)

# Pick the host's llama-server binary external (only it gets fetched).
config_setting(
    name = "_macos_arm64",
    constraint_values = ["@platforms//os:macos", "@platforms//cpu:arm64"],
)

config_setting(
    name = "_macos_amd64",
    constraint_values = ["@platforms//os:macos", "@platforms//cpu:x86_64"],
)

config_setting(
    name = "_linux_amd64",
    constraint_values = ["@platforms//os:linux", "@platforms//cpu:x86_64"],
)

config_setting(
    name = "_linux_arm64",
    constraint_values = ["@platforms//os:linux", "@platforms//cpu:arm64"],
)

alias(
    name = "llama_server",
    actual = select({
        ":_macos_arm64": "@llama_server_macos_arm64//:files",
        ":_macos_amd64": "@llama_server_macos_amd64//:files",
        ":_linux_amd64": "@llama_server_linux_amd64//:files",
        ":_linux_arm64": "@llama_server_linux_arm64//:files",
    }),
    # `manual` so `bazel test //...` (which builds non-test targets too —
    # --build_tests_only=false) doesn't build this and force-fetch the llama-server
    # http_archive onto the per-PR hot path. The embedding target's explicit
    # `data = [":llama_server"]` still pulls it in the dedicated embedding lane.
    tags = ["manual"],
)

# Integration conftest: spawns the server (//shrike-py/bin:server / //shrike-py/bin:server_embedding
# through runfiles — _server_launch_cmd), the MCP/CLI clients, the shared-server +
# per-test reset machinery, and (under Bazel) assembles the model externals into
# SHRIKE_TEST_MODEL_DIR + puts llama-server on PATH. model_cache.py rides along.
# imports=["../.."] puts the repo root on sys.path so tests.integration.model_cache
# resolves.
py_library(
    name = "conftest",
    srcs = [
        "backend_cases.py",
        "conftest.py",
        "model_cache.py",
    ],
    imports = ["../.."],
    data = ["//shrike-py/bin:server"],
    deps = [
        "//shrike-py/src/shrike",
        "@rules_python//python/runfiles",
        requirement("httpx"),
    ],
)

# The embedding-lane rosters, named here so :integration can be a GLOB minus
# these: an explicit srcs list silently orphans new files (a file on disk in no
# target runs in no CI lane). With the glob, a new test file lands in
# :integration by default; if it actually needs model externals it fails loudly
# there, and the author moves it into a lane.
# The out-of-process llama-server lane: the embedding-service lifecycle (health
# wiring, the /v1/embeddings canary, attach mode, orphan reaping, start/stop)
# against the pinned GGUF. The MINIMAL out-of-process surface — the
# backend-agnostic semantic behaviour runs in-process in _EMBEDDING_SEMANTIC.
_EMBEDDING_CORE = [
    "test_embedding.py",
]

# The in-process ONNX lane: semantic search / ranking / filters / neighbours /
# index updates against the in-process ONNX MiniLM backend — no llama-server, no
# GGUF download, no subprocess boot. Backend-agnostic behaviour.
_EMBEDDING_SEMANTIC = [
    "test_semantic.py",
]

_EMBEDDING_BACKENDS = [
    "test_backend_conformance.py",
    "test_backends.py",
    "test_clip_model.py",
    "test_fused_pipeline.py",
    "test_onnx_models.py",
]

# The manual adversarial search-quality suite: real CLIP + a downloaded
# Wikimedia Commons corpus, env-gated and NEVER named on a CI command line.
# Excluded from the :integration glob below so `bazel test //...` skips it.
_SEARCH_QUALITY = ["test_search_quality_realmodel.py"]

# Non-embedding integration: the server-spawn-bound suite (~230 tests), the
# slowest non-manual target and the per-PR wall-clock bottleneck. Glob-partitioned:
# everything that isn't an embedding lane OR the manual search-quality suite runs
# here.
#
# Sharded into 4 parallel Bazel test actions (`shard_count`) rather than one
# `-n auto` xdist action: the launcher round-robins the collected items across
# shards, each shard boots ONE shared session server and runs its ~1/4 SERIALLY
# (`xdist = None`). This is parallelism Bazel actually accounts for — each shard
# is one test job against `--local_test_jobs`, so the integration work interleaves
# with the rest of the graph under a bounded core budget, instead of a single
# action secretly spawning ncpu worker+server subprocesses the scheduler can't
# see (silent oversubscription). The pip lane keeps its own `pytest -n auto` (the
# conftest's per-xdist-worker server machinery still serves it); this only retunes
# the Bazel target.
pytest_test(
    name = "integration",
    size = "large",
    srcs = glob(
        ["test_*.py"],
        exclude = _EMBEDDING_CORE + _EMBEDDING_SEMANTIC + _EMBEDDING_BACKENDS + _SEARCH_QUALITY,
    ),
    shard_count = 4,
    xdist = None,
    deps = [":conftest"],
)

# Embedding integration: three `manual` targets (so the per-PR //... lane never
# fetches the hundreds of MB of model + llama-server externals; they run as
# part of the unified lane). Pulls models as pinned http_files
# and the host llama-server as an http_archive; the conftest assembles
# whichever are in a target's runfiles (atomically, so any future xdist
# workers can't race the copy). Each runs SERIALLY (xdist=None): it's
# model-load-bound with session/module-scoped servers, so one process = one
# boot per fixture — file-parallel xdist measured as a net LOSS here
# (each extra worker pays the full interpreter+import tax and oversubscribes
# the runner against the other concurrent test actions). The targets run
# CONCURRENTLY as separate Bazel test actions, so the lane's wall cost is
# ~max of them, not their sum.

# The llama-server core: the out-of-process embedding-service lifecycle (health
# wiring, the /v1/embeddings canary, attach mode, orphan reaping, start/stop)
# against the GGUF model — the minimal surface that proves the out-of-process
# backend loads and serves. The server binary comes from the conftest's
# //shrike-py/bin:server data-dep (the lean default — _server_launch_cmd falls
# back to it when server_embedding isn't in runfiles; llama is a subprocess, so
# the lean server suffices).
pytest_test(
    name = "embedding_core",
    size = "large",
    srcs = _EMBEDDING_CORE,
    tags = ["manual"],
    xdist = None,
    deps = [":conftest"],
    data = [
        ":llama_server",
        "@model_gguf_minilm//file",
    ],
)

# The in-process ONNX semantic suite: the backend-agnostic search behaviour
# (ranking, filters, neighbours, index updates) on the in-process ONNX MiniLM
# backend. No llama_server, no GGUF — server_embedding carries the onnx extras,
# and the MiniLM int8 graph + tokenizer are the only model externals it needs.
pytest_test(
    name = "embedding_semantic",
    size = "large",
    srcs = _EMBEDDING_SEMANTIC,
    tags = ["manual"],
    xdist = None,
    deps = [
        ":conftest",
        requirement("onnxruntime"),
        requirement("tokenizers"),
    ],
    data = [
        "//shrike-py/bin:server_embedding",
        "@model_minilm_int8_onnx//file",
        "@model_minilm_tokenizer//file",
    ],
)

# The backend zoo: per-backend contracts (llama / onnx fp32+int8 / clip,
# conformance + native-attach + the fused pipeline) and the model lineages.
# //shrike-py/bin:server_embedding carries the onnx/clip extras for the tests whose
# server loads a backend. Keeps llama_server + the GGUF too: test_backends
# exercises LlamaServerBackend alongside the in-process ones.
pytest_test(
    name = "embedding_backends",
    size = "large",
    srcs = _EMBEDDING_BACKENDS,
    tags = ["manual"],
    xdist = None,
    deps = [
        ":conftest",
        requirement("onnxruntime"),
        requirement("pillow"),
        requirement("tokenizers"),
    ],
    data = [
        ":llama_server",
        "//shrike-py/bin:server_embedding",
        "@model_clip_preprocessor//file",
        "@model_clip_text_onnx//file",
        "@model_clip_tokenizer//file",
        "@model_clip_vision_onnx//file",
        "@model_gguf_minilm//file",
        "@model_minilm_fp32_onnx//file",
        "@model_minilm_int8_onnx//file",
        "@model_minilm_tokenizer//file",
        "@model_roberta_int8_onnx//file",
        "@model_roberta_tokenizer//file",
    ],
)

# The manual adversarial search-quality suite — `manual`, NEVER named on
# a CI command line (unlike the embedding lanes, which the unified lane runs).
# `bazel test //...` skips it twice over: the :integration glob excludes it AND
# `manual` keeps `//...` from building it. It needs the CLIP + MiniLM ONNX
# externals (the real 2-space proof) and the in-process search-quality support
# (the shared metric engine + the Commons resolver + corpus). Run it explicitly:
#   SHRIKE_SEARCH_QUALITY=1 bazel test //shrike-py/tests/integration:search_quality
pytest_test(
    name = "search_quality",
    size = "large",
    srcs = _SEARCH_QUALITY,
    tags = ["manual"],
    xdist = None,
    deps = [
        ":conftest",
        "//shrike-py/tests/manual/search_quality",
        "//shrike-py/tests/manual/search_quality:inprocess",
        requirement("onnxruntime"),
        requirement("pillow"),
        requirement("tokenizers"),
    ],
    data = [
        "@model_clip_preprocessor//file",
        "@model_clip_text_onnx//file",
        "@model_clip_tokenizer//file",
        "@model_clip_vision_onnx//file",
        "@model_minilm_int8_onnx//file",
        "@model_minilm_tokenizer//file",
    ],
)

# The pinned-model fetch util on its own, non-testonly (overriding the package
# default) so non-test consumers can reuse it — the //scripts:serve_<profile> launcher
# imports its *_DIR_NAME constants + cached_*_model_dir fetchers as the single
# Python download source for its script-fallback lane. imports=["../.."] so it
# resolves as tests.integration.model_cache (matching the conftest's layout).
py_library(
    name = "model_cache",
    testonly = False,
    srcs = ["model_cache.py"],
    imports = ["../.."],
    visibility = ["//visibility:public"],
    deps = [requirement("httpx")],
)

# Source files for the //shrike-py:sdist source distribution. testonly=False (overriding
# the package default) so the non-testonly //shrike-py:sdist can stage them.
filegroup(
    name = "dist_files",
    testonly = False,
    srcs = glob(
        ["**"],
        exclude = ["BUILD.bazel", "**/__pycache__/**", "**/*.pyc", "**/*.pyo"],
    ),
    visibility = ["//visibility:public"],
)
