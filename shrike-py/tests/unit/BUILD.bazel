# The unit suite, split per source sub-library: each target depends on
# exactly the //shrike-py/src/shrike libraries its files exercise, so an edit to one
# module re-runs only the targets that transitively depend on it and the rest
# replay from cache. The floor is :conftest — pytest loads conftest.py for
# every file in this directory, and its wrapper/basic_note fixtures are built
# on the collection layer — so collection.py/schemas.py edits re-run the whole
# suite (honestly: the fixtures really do depend on them). Everything above
# that floor scopes: a tools.py edit re-runs :tools, not :client or :cli.
#
# A new test file must be added to exactly one cluster below — the fail()
# guard at the bottom turns a forgotten assignment into an analysis-time
# error instead of a test that silently never runs under Bazel.

# conftest.py (the wrapper/basic_note fixtures + the kernel harness)
# rides in the test's runfiles so pytest's per-directory conftest discovery
# finds it.
py_library(
    name = "conftest",
    srcs = [
        "_native_shims.py",
        "conftest.py",
    ],
    deps = [
        "//shrike-core/bindings/shrike-pyo3:shrike_native",  # _native_shims re-exports its errors
        "//shrike-py/src/shrike:collection",
        "//shrike-py/src/shrike:driven_runtime",  # the kharness fixture installs + drives the runtime
        "//shrike-py/tests/oracles",
        requirement("anki"),  # the pip TEST ORACLE (subprocess fixtures)
    ],
)

# Excluded from the Bazel unit suite (the pip `test` lane still runs both):
#  - test_model_cache.py imports tests.integration.model_cache, built in the
#    integration package.
#  - test_version.py asserts hatch-vcs generated _version.py; under Bazel the
#    version comes from stamping, so it stays on the pip lane.
_PIP_ONLY = [
    "test_model_cache.py",
    "test_version.py",
    # Reads tools/check_llama_lock.py + MODULE.bazel + tools/llama-server.lock by repo-relative
    # path (none in a unit target's runfiles); under Bazel the dedicated
    # //tools:llama_lock_in_sync_test is the authoritative tripwire.
    "test_llama_lock_sync.py",
]

