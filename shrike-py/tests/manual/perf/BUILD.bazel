load("@rules_python//python:defs.bzl", "py_library")
load("//tools/bazel:defs.bzl", "pytest_test")
load("@shrike_pip//:requirements.bzl", "requirement")

package(default_testonly = True)

# The PURE layer: distribution math + the result artifact + the baseline diff. No
# native, no harness, no boot — so `pure_test` runs on the per-PR //... lane
# without the native extension as a build prerequisite. (`result.Conditions.capture`
# imports shrike_native lazily, only on a live run — never at import.)
py_library(
    name = "perf_pure",
    srcs = [
        "__init__.py",
        "compare.py",
        "instrument.py",
        "result.py",
        "stats.py",
    ],
    imports = ["../../.."],  # repo root on sys.path so `tests.manual.perf.*` resolves
    visibility = ["//shrike-py/tests:__subpackages__"],
)

# The full harness support: the corpus generator (built through the REAL native
# write path) + the runner (boots the REAL Harness from a profile). Pulls
# shrike_native + the harness tier + pillow (procedural images) + pyyaml (profiles)
# on top of the pure layer. The heavy test targets below are `manual`.
py_library(
    name = "perf",
    srcs = [
        "corpus.py",
        "driver.py",
        "run.py",
        "workloads.py",
    ],
    data = glob(["profiles/*.yml"]),
    imports = ["../../.."],
    visibility = ["//shrike-py/tests:__subpackages__"],
    deps = [
        ":perf_pure",
        "//shrike-core/bindings/shrike-pyo3:shrike_native",
        "//shrike-py/src/shrike:actions",
        "//shrike-py/src/shrike:collection",
        "//shrike-py/src/shrike:derived",
        "//shrike-py/src/shrike:driven_runtime",
        "//shrike-py/src/shrike:embedding",
        "//shrike-py/src/shrike:harness",
        "//shrike-py/src/shrike:log",
        "//shrike-py/src/shrike:profiles",
        "//shrike-py/src/shrike:schemas",
        requirement("pillow"),
        requirement("pyyaml"),
    ],
)

# The pure distribution / artifact / diff logic — runs on the per-PR //... lane
# (the math + serialization is where regressions hide). Depends only on the pure
# layer, so it needs no native build.
pytest_test(
    name = "pure_test",
    size = "small",
    srcs = [
        "test_instrument.py",
        "test_result.py",
        "test_stats.py",
    ],
    deps = [":perf_pure"],
)

# The corpus generator: builds tiny collections through the native write path.
# `manual` — the perf lane is benchmarking infra, off the per-PR critical path.
pytest_test(
    name = "corpus_test",
    size = "small",
    srcs = ["test_corpus.py"],
    tags = ["manual"],
    deps = [":perf"],
)

# The runner smoke: boots perf-stub (synthetic) + times each workload. `manual`,
# and it skips unless engine-synthetic is compiled — it boots a kernel + the
# committed driver threads.
pytest_test(
    name = "run_test",
    size = "medium",
    srcs = ["test_run.py"],
    tags = ["manual"],
    deps = [":perf"],
)

# Source files for the //shrike-py:sdist source distribution.
filegroup(
    name = "dist_files",
    testonly = False,
    srcs = glob(
        ["**"],
        exclude = ["BUILD.bazel", "**/__pycache__/**", "**/*.pyc", "**/*.pyo"],
    ),
    visibility = ["//visibility:public"],
)
