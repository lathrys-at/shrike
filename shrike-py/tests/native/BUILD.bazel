load("@rules_python//python:defs.bzl", "py_library")
load("//tools/bazel:defs.bzl", "pytest_test")
load("@shrike_pip//:requirements.bzl", "requirement")

package(default_testonly = True)

py_library(
    name = "conftest",
    srcs = [
        "__init__.py",
        "conftest.py",
    ],
    deps = [
        "//shrike-py/src/shrike",
        "//shrike-py/tests/oracles",
        requirement("anki"),  # the pip TEST ORACLE (cross-core parity subprocesses)
    ],
)

# The native binding + kernel-assembly suite (asyncio bridge, AsyncKernel,
# KernelIndex, Harness, the collection-core parity harness). These 50+ binding
# tests gate PRs.
pytest_test(
    name = "native",
    srcs = glob(["test_*.py"]),
    deps = [
        ":conftest",
        # test_search_fusion_native.py drives the REAL search_notes action in-process
        # via the StubEmbedder + the shared metric engine.
        "//shrike-py/tests/manual/search_quality",
        "//shrike-py/tests/manual/search_quality:inprocess",
    ],
    size = "medium",
)

# Source files for the //shrike-py:sdist source distribution.
filegroup(
    name = "dist_files",
    testonly = False,
    srcs = glob(
        ["**"],
        exclude = ["BUILD.bazel", "**/__pycache__/**", "**/*.pyc", "**/*.pyo"],
    ),
    visibility = ["//visibility:public"],
)
