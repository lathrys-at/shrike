# Optional direnv sugar: auto-activate the coexistence .venv for the pip
# lane (pytest, ruff, mypy). Nothing requires this — the committed ./bazel
# wrapper needs no environment at all, and without direnv installed this
# file is inert. Enable with `direnv allow`.
if [[ -d .venv ]]; then
  export VIRTUAL_ENV="$PWD/.venv"
  PATH_add .venv/bin

  # Keep the native extension fresh on cd (#573). The fresh case short-circuits
  # silently (well under 100ms — git plumbing, no compile); a stale extension is rebuilt
  # right here so the interactive shell is always ready. A build failure never
  # blocks the shell — it warns and lets you in (the pytest backstop in
  # tests/conftest.py is the hard gate). SHRIKE_ENVRC_WARN_ONLY=1 opts out of the
  # auto-rebuild and only warns.
  if ! scripts/native-stale.sh; then
    if [[ "${SHRIKE_ENVRC_WARN_ONLY:-}" == "1" ]]; then
      log_status "shrike_native is stale — run scripts/build-native.sh (SHRIKE_ENVRC_WARN_ONLY=1)"
    else
      log_status "shrike_native is stale — rebuilding (scripts/build-native.sh)…"
      if scripts/build-native.sh >/dev/null 2>&1; then
        log_status "shrike_native rebuilt"
      else
        log_status "shrike_native rebuild FAILED — run scripts/build-native.sh by hand"
      fi
    fi
  fi
fi
