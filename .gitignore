.DS_Store
.venv/
__pycache__/
*.egg-info/
*.pyc
.mypy_cache/
.pytest_cache/
.ruff_cache/
# Ignore the repo-root dev cache's contents (not the dir itself, so the anchor
# below can be re-included) — keep the committed anchor for cargo's TMPDIR
# redirect (shrike-core/.cargo/config.toml [env] TMPDIR): the dir must exist
# before the first rustc/rustdoc temp write; its contents stay ignored.
/.cache/*
!/.cache/cargo-tmp/
/.cache/cargo-tmp/*
!/.cache/cargo-tmp/.gitkeep
.coverage
.coverage.*
coverage.xml
htmlcov/
.testmondata

# Generated at build time by hatch-vcs (see shrike-py/pyproject.toml; relocated #731)
shrike-py/src/shrike/_version.py

# Bazel (epic #241): convenience symlinks + machine-local rc. The pinned
# launcher (./bazel) and bazelisk caches live under ~/.cache, not the repo.
/bazel-*
.bazelrc.user

# Rust/cargo build output (native extensions — #247). Cargo.lock IS committed
# (crate_universe resolves against it); only the build dir is ignored.
target/

# QA harness working dir — regenerated each launch (eval/run.py)
shrike-py/tests/manual/skill_quality/run/

# //scripts:serve launcher per-run output (script-fallback lane; #656)
scripts/.run/

# Packaged skills (scripts/package-skill.py)
dist/
shrike-py/tests/manual/skill_quality/runs/

# QA skill-variant A/B copies — throwaway; the swap script (use-variant.sh) is tracked
shrike-py/tests/manual/skill_quality/variants/*/

# Multimodal eval image-bytes cache (URLs are pinned in resolved_urls.json)
eval/multimodal/cache/

# Search-quality eval image-bytes cache (#559): URLs pinned in resolved_urls.json,
# attribution in ASSETS.md — the Commons bytes are NEVER committed (downloaded
# on demand by the manual suite).
shrike-py/tests/manual/search_quality/cache/
# The PR2b runner's generated report (a local artifact, not committed).
shrike-py/tests/manual/search_quality/RESULTS.md

# Fuzzy-recall eval (#927): the auto-generated scratch report is not committed;
# a curated, named snapshot (RESULTS_927.md) is. The misspellings-list bytes are
# NEVER committed (downloaded on demand; pin + attribution in ASSETS.md).
shrike-py/tests/manual/fuzzy_recall/RESULTS.md
.cache/fuzzy_recall/

# MobileCLIP2 spike (#568): model bytes are NEVER committed — fetched on demand
# into this gitignored scratch cache. Only the verify script + RESULTS.md +
# ASSETS.md (pinned URLs/attribution) are committed.
eval/mobileclip/cache/

# Claude Code agent worktrees — transient, created by parallel subagents.
.claude/worktrees/
