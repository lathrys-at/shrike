.DS_Store
.venv/
__pycache__/
*.egg-info/
*.pyc
.mypy_cache/
.pytest_cache/
.ruff_cache/
.cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.testmondata

# Generated at build time by hatch-vcs (see pyproject.toml)
src/shrike/_version.py

# Bazel (epic #241): convenience symlinks + machine-local rc. The pinned
# launcher (./bazel) and bazelisk caches live under ~/.cache, not the repo.
/bazel-*
.bazelrc.user

# Rust/cargo build output (native extensions — #247). Cargo.lock IS committed
# (crate_universe resolves against it); only the build dir is ignored.
target/

# QA harness working dir — regenerated each launch (eval/run.py)
tests/manual/skill_quality/run/

# //scripts:serve launcher per-run output (script-fallback lane; #656)
scripts/.run/

# Packaged skills (scripts/package-skill.py)
dist/
tests/manual/skill_quality/runs/

# QA skill-variant A/B copies — throwaway; the swap script (use-variant.sh) is tracked
tests/manual/skill_quality/variants/*/

# Multimodal eval image-bytes cache (URLs are pinned in resolved_urls.json)
eval/multimodal/cache/

# Search-quality eval image-bytes cache (#559): URLs pinned in resolved_urls.json,
# attribution in ASSETS.md — the Commons bytes are NEVER committed (downloaded
# on demand by the manual suite).
eval/search_quality/cache/
# The PR2b runner's generated report (a local artifact, not committed).
eval/search_quality/RESULTS.md

# MobileCLIP2 spike (#568): model bytes are NEVER committed — fetched on demand
# into this gitignored scratch cache. Only the verify script + RESULTS.md +
# ASSETS.md (pinned URLs/attribution) are committed.
eval/mobileclip/cache/
