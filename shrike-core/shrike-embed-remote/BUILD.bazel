load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

package(default_visibility = ["//shrike-core:__subpackages__"])

exports_files(["Cargo.toml"])

# The generic remote-embeddings engine (#342 P4): EmbedText over any
# OpenAI-compatible endpoint, ureq (synchronous, runtime-less). Knows
# nothing about subprocesses.
rust_library(
    name = "shrike_embed_remote",
    srcs = glob(["src/**/*.rs"]),
    edition = "2021",
    deps = [
        "//shrike-core/shrike-engine-api:shrike_engine_api",
        "//shrike-core/shrike-error:shrike_error",
        "//shrike-core/shrike-net:shrike_net",
        "@crates//:base64",
        "@crates//:serde",
        "@crates//:serde_json",
        "@crates//:tracing",
        "@crates//:ureq",
        "@crates//:url",
    ],
)

rust_test(
    name = "shrike_embed_remote_test",
    size = "small",
    crate = ":shrike_embed_remote",
)
