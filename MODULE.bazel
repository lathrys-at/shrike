"""Shrike build module (bzlmod).

Bazel is the polyglot build/test/package entry point (epic #241). This module
wires the hermetic Python toolchain and the PyPI dependency set; later phases add
rules_rust + a PyO3 extension (#247) behind the same graph. The legacy WORKSPACE
file is intentionally absent — bzlmod only.
"""

module(
    name = "shrike",
    # Build-system module version only. The *wheel* version is stamped from the
    # git tag at package time (Phase 3, #245), not taken from here.
    version = "0.0.0",
)

bazel_dep(name = "rules_python", version = "2.0.2")
bazel_dep(name = "rules_cc", version = "0.2.19")  # Bazel 9 removed the native cc_* rules (#420)

# Hermetic CPython, matching .python-version's minor (3.12). The patch level is
# whatever python-build-standalone build rules_python bundles for this version;
# pinning the *minor* is what governs manylinux/macOS wheel compatibility.
python = use_extension("@rules_python//python/extensions:python.bzl", "python")
python.toolchain(
    python_version = "3.12",
    is_default = True,
    # Register the bundled coverage tool so `bazel coverage` actually collects data
    # (without it, coverage.dat comes out empty). Backs the coverage lane (#262).
    configure_coverage_tool = True,
)

# Third-party Python deps come from PyPI as wheels — including the native ones
# (anki's bundled Rust backend, usearch C++, onnxruntime C++, tokenizers Rust) —
# resolved against a pinned, hashed lock. Bazel never rebuilds them from source.
pip = use_extension("@rules_python//python/extensions:pip.bzl", "pip")
pip.parse(
    hub_name = "shrike_pip",
    python_version = "3.12",
    requirements_lock = "//:requirements_lock.txt",
)
use_repo(pip, "shrike_pip")

# Build-time tools for //:sdist (build / hatchling / hatch-vcs), in their own hub +
# lock so they never enter the runtime dependency set (requirements_lock.txt).
pip.parse(
    hub_name = "shrike_sdist_pip",
    python_version = "3.12",
    requirements_lock = "//:requirements_sdist_lock.txt",
)
use_repo(pip, "shrike_sdist_pip")

# ── Rust toolchain + crates: the native compute workspace (#247 → #269) ─────
# rules_rust builds the Shrike native crates (shrike-core/Cargo.toml workspace)
# against the hermetic CPython. The PyO3 binding crate (shrike-py) and the
# polyglot-proof demo are the only crates that see pyo3 (//shrike-core:layering_check
# enforces it); compute crates stay pure Rust. crate deps resolve from the
# workspace's single Cargo.lock via the rust toolchain's own cargo — no system
# Rust required.
bazel_dep(name = "rules_rust", version = "0.70.0")
bazel_dep(name = "platforms", version = "1.0.0")
bazel_dep(name = "bazel_skylib", version = "1.8.2")  # copy_file (the .so rename)
bazel_dep(name = "rules_pkg", version = "1.0.1")  # the create-cards.skill bundle (#245)

rust = use_extension("@rules_rust//rust:extensions.bzl", "rust")
rust.toolchain(edition = "2021")
use_repo(rust, "rust_toolchains")

register_toolchains("@rust_toolchains//:all")

crate = use_extension("@rules_rust//crate_universe:extensions.bzl", "crate")
crate.from_cargo(
    name = "crates",
    cargo_lockfile = "//shrike-core:Cargo.lock",
    manifests = [
        "//shrike-core:Cargo.toml",
        "//shrike-core/shrike-collection:Cargo.toml",
        "//shrike-core/shrike-derived:Cargo.toml",
        "//shrike-core/shrike-embed:Cargo.toml",
        "//shrike-core/shrike-embed-remote:Cargo.toml",
        "//shrike-core/shrike-describe-remote:Cargo.toml",
        "//shrike-core/shrike-engine-api:Cargo.toml",
        "//shrike-core/shrike-ffi:Cargo.toml",
        "//shrike-core/shrike-index:Cargo.toml",
        "//shrike-core/shrike-kernel:Cargo.toml",
        "//shrike-core/shrike-llama-server:Cargo.toml",
        "//shrike-core/shrike-py:Cargo.toml",
        "//shrike-core/shrike-recognize-apple:Cargo.toml",
        "//shrike-core/shrike-schemas:Cargo.toml",
    ],
)
# Temporary: `@crates//:pyo3-log` resolves to the fork pinned by the
# `[patch.crates-io]` in //shrike-core:Cargo.toml (lathrys-at/pyo3-log = v0.13.3 with
# a widened pyo3 bound) — the crates.io release caps pyo3 at `<0.29`, blocking
# the RUSTSEC-2026-0176/-0177 bump. crate_universe vendors the git rev, pinned
# by its immutable commit SHA in MODULE.bazel.lock. Drop the patch once upstream
# ships a 0.29-compatible pyo3-log (Cleanup milestone, #519).
# usearch's cxx_build leaves OUT_DIR symlinks into the ephemeral build sandbox,
# which Bazel's output-tree validation rejects as dangling; the patch
# materializes/drops them (no behaviour change under plain cargo).
crate.annotation(
    crate = "usearch",
    patch_args = ["-p1"],
    patches = ["//shrike-core/patches:usearch-bazel-cxxbridge-symlink.patch"],
)
# cxx's C++ object (cxx_cc) needs GCC's STATIC libgcc.a on aarch64-linux (the
# outline-atomics helpers, #417); the shim dep appends a linux-only -lgcc to
# the link AFTER -lcxx_cc — gold resolves archives left to right, so position
# is the whole fix (a global --linkopt lands too early and resolves nothing).
crate.annotation(
    crate = "cxx",
    # REPLACES the metadata-supplied deps, so :cxx_cc (the crate's own C++
    # runtime, normally injected by its [package.metadata.bazel]) must be
    # restated alongside the shim.
    deps = [
        ":cxx_cc",
        "@@//shrike-core/patches:libgcc_shim",
    ],
)
# The anki tree under Bazel (#278 cutover): both anki build scripts run off
# the CHECKED-IN pinned protobuf descriptor set (//shrike-core/third_party/anki,
# refreshed by scripts/update-anki-descriptors.sh on tag bumps, tripwire-tested
# under Bazel) instead of cargo's shared-target-dir handoff, which doesn't
# exist across Bazel sandboxes. anki_proto is additionally patched (Bazel-only;
# cargo builds the unpatched checkout) to generate via prost's compile_fds —
# no protoc and no source-repo proto/ access, neither of which the sandbox
# has — and to stop writing generated py/ts interfaces into the read-only
# source repo.
crate.annotation(
    crate = "anki_proto",
    build_script_data = ["@@//shrike-core/third_party/anki:anki_descriptors.bin"],
    build_script_env = {
        "DESCRIPTORS_BIN": "$(execpath @@//shrike-core/third_party/anki:anki_descriptors.bin)",
    },
    patch_args = ["-p1"],
    patches = [
        "//shrike-core/patches:anki-proto-bazel-buildrs.patch",
        "//shrike-core/patches:anki-proto-bazel-rustrs.patch",
    ],
)
crate.annotation(
    crate = "anki_i18n",
    build_script_data = ["@@+http_archive+anki_src//:ftl"],
    build_script_env = {
        # The pinned source archive's ftl tree (see @anki_src). EXTRA_FTL_ROOT
        # being set selects the no-qt branch of get_ftl_data; the patched
        # gather.rs tolerates the dir not existing.
        "EXTRA_FTL_ROOT": "_absent_",
        "FTL_BASE": "$(execpath @@+http_archive+anki_src//:ftl)",
    },
    patch_args = ["-p1"],
    patches = [
        "//shrike-core/patches:anki-i18n-bazel-build.patch",
        "//shrike-core/patches:anki-i18n-bazel-gather.patch",
    ],
)
crate.annotation(
    crate = "anki",
    build_script_data = ["@@//shrike-core/third_party/anki:anki_descriptors.bin"],
    patch_args = ["-p1"],
    patches = ["//shrike-core/patches:anki-version-bazel.patch"],
    build_script_env = {
        "DESCRIPTORS_BIN": "$(execpath @@//shrike-core/third_party/anki:anki_descriptors.bin)",
    },
)
use_repo(crate, "crates")

http_archive = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

# The pinned anki SOURCE archive (#278 cutover): the anki_i18n build script
# needs the repo's ftl/ template strings, which the per-crate Bazel package
# doesn't carry. The github tag tarball is pinned + checksummed (no submodules
# — the translation repos are tolerated as absent; English-only strings, which
# is all the backend needs).
http_archive(
    name = "anki_src",
    build_file_content = """
package(default_visibility = ["//visibility:public"])
exports_files(["ftl"])
""",
    sha256 = "e9fda82b3b57fba3a416d8f91cf4db64368dd2f0bc02090d626df081572333c6",
    strip_prefix = "anki-25.09.4",
    urls = ["https://github.com/ankitects/anki/archive/refs/tags/25.09.4.tar.gz"],
)

