  {
    "name": "upsert_note_types",
    "description": "Create or update note type definitions (1-10 per call).\n\n        A note type defines the schema for notes: its fields, card templates\n        (front/back HTML), and shared CSS styling.\n\n        If a note type object includes an `id`, the existing note type is\n        updated; if `id` is absent, a new note type is created. For new note\n        types, `name`, `fields`, `templates`, and `css` are required.\n\n        Card templates use Anki's replacement syntax: {{FieldName}} inserts\n        a field value, {{FrontSide}} on the back template inserts the\n        rendered front side. Cloze note types use {{cloze:FieldName}}.\n\n        Note: removing fields from an existing note type deletes that\n        field's data from all notes of that type.",
    "inputSchema": {
      "$defs": {
        "NoteTypeInput": {
          "properties": {
            "id": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Note type ID. Present = update, absent = create.",
              "title": "Id"
            },
            "name": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Name for the note type. Required for new note types.",
              "title": "Name"
            },
            "fields": {
              "anyOf": [
                {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Ordered list of field names. Required for new note types. On update, replaces the full field list.",
              "title": "Fields"
            },
            "templates": {
              "anyOf": [
                {
                  "items": {
                    "$ref": "#/$defs/TemplateInput"
                  },
                  "type": "array"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Card templates. Required for new note types.",
              "title": "Templates"
            },
            "css": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "CSS styling shared across all cards. Required for new note types.",
              "title": "Css"
            },
            "is_cloze": {
              "anyOf": [
                {
                  "type": "boolean"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "If true, this is a cloze deletion note type. Cannot be changed on update.",
              "title": "Is Cloze"
            }
          },
          "title": "NoteTypeInput",
          "type": "object"
        },
        "TemplateInput": {
          "properties": {
            "name": {
              "description": "Template name (e.g., 'Recognition', 'Recall').",
              "title": "Name",
              "type": "string"
            },
            "front": {
              "description": "Front side HTML. Use {{FieldName}} to insert field values.",
              "title": "Front",
              "type": "string"
            },
            "back": {
              "description": "Back side HTML. Use {{FieldName}} for fields and {{FrontSide}} to insert the rendered front side.",
              "title": "Back",
              "type": "string"
            }
          },
          "required": [
            "name",
            "front",
            "back"
          ],
          "title": "TemplateInput",
          "type": "object"
        }
      },
      "properties": {
        "note_types": {
          "description": "Array of note type definitions to create or update.",
          "items": {
            "$ref": "#/$defs/NoteTypeInput"
          },
          "maxItems": 10,
          "minItems": 1,
          "title": "Note Types",
          "type": "array"
        }
      },
      "required": [
        "note_types"
      ],
      "title": "upsert_note_typesArguments",
      "type": "object"
    },
    "outputSchema": {
      "$defs": {
        "NoteTypeResult": {
          "properties": {
