load("@rules_python//python:defs.bzl", "py_library")
load("//tools/bazel:defs.bzl", "pytest_test")
load("@shrike_pip//:requirements.bzl", "requirement")

package(default_testonly = True)

# conftest.py (the wrapper/basic_note fixtures + the #355 kernel harness)
# rides in the test's runfiles so pytest's per-directory conftest discovery
# finds it.
py_library(
    name = "conftest",
    srcs = [
        "_native_shims.py",
        "conftest.py",
    ],
    deps = [
        "//src/shrike",
        "//tests/oracles",
        requirement("anki"),  # the pip TEST ORACLE (subprocess fixtures)
    ],
)

# Excluded from the Bazel unit suite for now (the pip `test` lane still runs both):
#  - test_model_cache.py imports tests.integration.model_cache, built in the
#    integration/embedding migration (#244 Phase 2b/2c).
#  - test_version.py asserts hatch-vcs generated _version.py; under Bazel the
#    version comes from stamping (Phase 3 / #245), so it stays on the pip lane
#    until that lands.
_PIP_ONLY = [
    "test_model_cache.py",
    "test_version.py",
]

# One aggregate target: every unit file runs in a single test action with
# `-n auto` (xdist, the macro default), so the heavy anki/usearch/pydantic import
# is paid once per worker and the suite parallelizes across cores — the same model
# as the pip `pytest -n auto` lane, not ~60 cold one-file processes. pytest still
# reports per-test pass/fail, and `bazel test //tests/unit:unit --test_filter=EXPR`
# (-> pytest -k) runs a subset.
# TODO(#259): once src/shrike is split into sub-libraries, split this into one
# target per library so a lib change re-runs only its dependent tests — the grain
# at which Bazel caching pays off (per-file finer than that buys nothing).
pytest_test(
    name = "unit",
    srcs = glob(["test_*.py"], exclude = _PIP_ONLY),
    deps = [":conftest"],
    size = "medium",
)

# Source files for the //:sdist source distribution (#245). testonly=False (overriding
# the package default) so the non-testonly //:sdist can stage them.
filegroup(
    name = "dist_files",
    testonly = False,
    srcs = glob(
        ["**"],
        exclude = ["BUILD.bazel", "**/__pycache__/**", "**/*.pyc", "**/*.pyo"],
    ),
    visibility = ["//visibility:public"],
)
