# Analysis-time completeness guard: every test_*.py must be named in exactly
# one cluster (or _PIP_ONLY). A forgotten file fails the build loudly here
# instead of silently never running under Bazel.
_ASSIGNED = _PIP_ONLY + _CORE + _CLIENT + _DAEMON + _LOG + _INDEX + _CACHE_LAYOUT + \
            _HARNESS + _PATHSAFETY + _DERIVED + \
            _EMBED_HELPERS + _EMBEDDING + _SEARCH_QUALITY + _ACTIONS + _TOOLS + \
            _SERVER + _CONFIG + _CLI

_UNASSIGNED = glob(
    ["test_*.py"],
    exclude = _ASSIGNED,
    # Empty IS the expected state: every file assigned to a cluster above.
    allow_empty = True,
)

_GUARD = fail("unit test files not assigned to any target in tests/unit/BUILD.bazel " +
              "(add each to a cluster list): %s" % _UNASSIGNED) if _UNASSIGNED else None

# Source files for the //:sdist source distribution (#245). testonly=False (overriding
# the package default) so the non-testonly //:sdist can stage them.
filegroup(
    name = "dist_files",
    testonly = False,
    srcs = glob(
        ["**"],
        exclude = ["BUILD.bazel", "**/__pycache__/**", "**/*.pyc", "**/*.pyo"],
    ),
    visibility = ["//visibility:public"],
)
