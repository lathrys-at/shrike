# The unit suite, split per source sub-library (#259): each target depends on
# exactly the //src/shrike libraries its files exercise, so an edit to one
# module re-runs only the targets that transitively depend on it and the rest
# replay from cache. The floor is :conftest — pytest loads conftest.py for
# every file in this directory, and its wrapper/basic_note fixtures are built
# on the collection layer — so collection.py/schemas.py edits re-run the whole
# suite (honestly: the fixtures really do depend on them). Everything above
# that floor scopes: a tools.py edit re-runs :tools, not :client or :cli.
#
# A new test file must be added to exactly one cluster below — the fail()
# guard at the bottom turns a forgotten assignment into an analysis-time
# error instead of a test that silently never runs under Bazel (the #285
# lesson, when tests/native fell off the CI lanes unnoticed).

# conftest.py (the wrapper/basic_note fixtures + the #355 kernel harness)
# rides in the test's runfiles so pytest's per-directory conftest discovery
# finds it.
py_library(
    name = "conftest",
    srcs = [
        "_native_shims.py",
        "conftest.py",
    ],
    deps = [
        "//native/shrike-py:shrike_native",  # _native_shims re-exports its errors
        "//src/shrike:collection",
        "//tests/oracles",
        requirement("anki"),  # the pip TEST ORACLE (subprocess fixtures)
    ],
)

