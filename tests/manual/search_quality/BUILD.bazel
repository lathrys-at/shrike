load("@rules_python//python:defs.bzl", "py_library")
load("@shrike_pip//:requirements.bzl", "requirement")

package(default_testonly = True)

# The shared search-quality support (#559): the pure metric engine + the
# manifest loader + the Commons resolve→pin→cache module (the manual corpus's
# image sourcing). Native-free (no shrike_native, no harness) so the unit suite
# can depend on the metric engine; ``commons`` needs ``httpx`` (the Commons API)
# but only the manual suite imports it. The fixtures ride along as data for the
# manifest-loader tests. The in-process driver (which needs the native extension
# + the harness) is a SEPARATE library below so a unit-only consumer doesn't
# pull the kernel.
py_library(
    name = "search_quality",
    srcs = [
        "__init__.py",
        "commons.py",
        "manifest.py",
        "metrics.py",
    ],
    data = glob([
        "fixtures/**",
        # the committed corpus data (read at runtime by the manual suite);
        # the gitignored cache/ + RESULTS.md are never present at build time.
        "manifest.json",
        "resolved_urls.json",
        "ASSETS.md",
    ]),
    imports = ["../../.."],  # repo root on sys.path so `tests.manual.search_quality.*` resolves
    visibility = ["//tests:__subpackages__"],
    deps = [requirement("httpx")],
)

# The in-process harness driver + the real-model run engine (#559 PR2b): a real
# Harness over a throwaway collection driving the REAL search_notes action.
# Needs the native extension and the harness, so it's split off the native-free
# base above. ``runner`` also imports ``tests.integration.model_cache`` (the
# cached CLIP/MiniLM backends) — provided at runtime by the manual suite target's
# ``:conftest`` dep, so it isn't named here (the unit suite never imports runner).
py_library(
    name = "inprocess",
    srcs = [
        "inprocess.py",
        "runner.py",
    ],
    imports = ["../../.."],
    visibility = ["//tests:__subpackages__"],
    deps = [
        ":search_quality",
        "//native/shrike-py:shrike_native",
        "//src/shrike:derived",
        "//src/shrike:embedding",
        "//src/shrike:harness",
        "//src/shrike:tools",
    ],
)

# Source files for the //:sdist source distribution (#245).
filegroup(
    name = "dist_files",
    testonly = False,
    srcs = glob(
        ["**"],
        exclude = ["BUILD.bazel", "**/__pycache__/**", "**/*.pyc", "**/*.pyo"],
    ),
    visibility = ["//visibility:public"],
)
