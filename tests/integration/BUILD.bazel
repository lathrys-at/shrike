load("@rules_python//python:defs.bzl", "py_library")
load("@shrike_pip//:requirements.bzl", "requirement")
load("//tools/bazel:defs.bzl", "pytest_test")

package(default_testonly = True)

# Pick the host's llama-server binary external (only it gets fetched).
config_setting(
    name = "_macos_arm64",
    constraint_values = ["@platforms//os:macos", "@platforms//cpu:arm64"],
)

config_setting(
    name = "_macos_amd64",
    constraint_values = ["@platforms//os:macos", "@platforms//cpu:x86_64"],
)

config_setting(
    name = "_linux_amd64",
    constraint_values = ["@platforms//os:linux", "@platforms//cpu:x86_64"],
)

config_setting(
    name = "_linux_arm64",
    constraint_values = ["@platforms//os:linux", "@platforms//cpu:arm64"],
)

alias(
    name = "llama_server",
    actual = select({
        ":_macos_arm64": "@llama_server_macos_arm64//:files",
        ":_macos_amd64": "@llama_server_macos_amd64//:files",
        ":_linux_amd64": "@llama_server_linux_amd64//:files",
        ":_linux_arm64": "@llama_server_linux_arm64//:files",
    }),
    # `manual` so `bazel test //...` (which builds non-test targets too —
    # --build_tests_only=false) doesn't build this and force-fetch the llama-server
    # http_archive onto the per-PR hot path. The embedding target's explicit
    # `data = [":llama_server"]` still pulls it in the dedicated embedding lane.
    tags = ["manual"],
)

# Integration conftest: spawns the server (//bin:server / //bin:server_embedding
# through runfiles — _server_launch_cmd), the MCP/CLI clients, the shared-server +
# per-test reset machinery, and (under Bazel) assembles the model externals into
# SHRIKE_TEST_MODEL_DIR + puts llama-server on PATH. model_cache.py rides along.
# imports=["../.."] puts the repo root on sys.path so tests.integration.model_cache
# resolves.
py_library(
    name = "conftest",
    srcs = [
        "conftest.py",
        "model_cache.py",
    ],
    imports = ["../.."],
    data = ["//bin:server"],
    deps = [
        "//src/shrike",
        "@rules_python//python/runfiles",
        requirement("httpx"),
    ],
)

# Non-embedding integration: one aggregate target, `-n auto` (xdist), mirroring the
# pip `pytest tests/integration -n auto` lane — import + server-spawn cost amortized.
pytest_test(
    name = "integration",
    size = "large",
    srcs = [
        "test_cli.py",
        "test_media.py",
        "test_security.py",
        "test_tools.py",
    ],
    deps = [":conftest"],
)

# Embedding integration: two `manual` halves (so the per-PR //... lane never
# fetches the hundreds of MB of model + llama-server externals; they run as a
# gated step in the bazel lane, #262/#418). Pulls models as pinned http_files and
# the host llama-server as an http_archive; the conftest assembles whichever are
# in a target's runfiles. Each half runs SERIALLY (xdist=None): it's
# model-load-bound with session-scoped servers, so one process = one llama boot +
# one load of each model, not N — but the two halves run CONCURRENTLY as separate
# Bazel test actions, each booting only its own models, so the lane's wall cost
# is ~max of the halves instead of their sum. Split balanced by measured per-file
# cost (#418: core ≈ 12s, backends ≈ 17s locally), not by theme alone.

# The llama-server core: the embedding-service lifecycle (incl. orphan reaping)
# + semantic search / neighbors / index CLI against the GGUF model. The server
# binary comes from the conftest's //bin:server data-dep (the lean default —
# _server_launch_cmd falls back to it when server_embedding isn't in runfiles).
pytest_test(
    name = "embedding_core",
    size = "large",
    srcs = [
        "test_embedding.py",
        "test_semantic.py",
    ],
    tags = ["manual"],
    xdist = None,
    deps = [":conftest"],
    data = [
        ":llama_server",
        "@model_gguf_minilm//file",
    ],
)

# The backend zoo: per-backend contracts (llama / onnx fp32+int8 / clip) and the
# model lineages. //bin:server_embedding carries the onnx/clip extras for the
# tests whose server loads a backend (test_backends). Keeps llama_server + the
# GGUF too: test_backends exercises LlamaServerBackend alongside the in-process
# ones.
pytest_test(
    name = "embedding_backends",
    size = "large",
    srcs = [
        "test_backends.py",
        "test_clip_model.py",
        "test_onnx_models.py",
    ],
    tags = ["manual"],
    xdist = None,
    deps = [
        ":conftest",
        requirement("onnxruntime"),
        requirement("pillow"),
        requirement("tokenizers"),
    ],
    data = [
        ":llama_server",
        "//bin:server_embedding",
        "@model_clip_preprocessor//file",
        "@model_clip_text_onnx//file",
        "@model_clip_tokenizer//file",
        "@model_clip_vision_onnx//file",
        "@model_gguf_minilm//file",
        "@model_minilm_fp32_onnx//file",
        "@model_minilm_int8_onnx//file",
        "@model_minilm_tokenizer//file",
        "@model_roberta_int8_onnx//file",
        "@model_roberta_tokenizer//file",
    ],
)

# Source files for the //:sdist source distribution (#245). testonly=False (overriding
# the package default) so the non-testonly //:sdist can stage them.
filegroup(
    name = "dist_files",
    testonly = False,
    srcs = glob(
        ["**"],
        exclude = ["BUILD.bazel", "**/__pycache__/**", "**/*.pyc", "**/*.pyo"],
    ),
    visibility = ["//visibility:public"],
)
